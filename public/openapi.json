{
    "openapi": "3.1.0",
    "info": {
        "title": "ScreensPizza API",
        "version": "1.0.0",
        "description": "Comprehensive API specification for station management and LiveKit administration.\n\nStore scoping model:\n- `storeId` is the external store number (`stores.store_number`, string).\n- API resolves `storeId` to internal numeric `stores.id` before querying stations/rooms.\n- Store-scoped endpoints return 404 when target resources do not belong to the provided store."
    },
    "servers": [
        {
            "url": "/api",
            "description": "Laravel API base path"
        }
    ],
    "tags": [
        { "name": "Stations" },
        { "name": "Station Participants (Legacy)" },
        { "name": "Tokens" },
        { "name": "LiveKit Rooms" },
        { "name": "LiveKit Participants" }
    ],
    "paths": {
        "/{storeId}/stations": {
            "get": {
                "tags": ["Stations"],
                "summary": "List stations",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "description": "External store number (`stores.store_number`).",
                        "schema": { "type": "string" },
                        "example": "S-1001"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Stations list",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Station"
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" }
                }
            },
            "post": {
                "tags": ["Stations"],
                "summary": "Create station",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "description": "External store number (`stores.store_number`).",
                        "schema": { "type": "string" },
                        "example": "S-1001"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["name", "room_name"],
                                "properties": {
                                    "name": { "type": "string" },
                                    "room_name": { "type": "string" }
                                }
                            },
                            "example": {
                                "name": "Counter 1",
                                "room_name": "store-1001-counter-1"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Station created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Station"
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        },
        "/{storeId}/stations/{station}": {
            "delete": {
                "tags": ["Stations"],
                "summary": "Delete station",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" },
                        "description": "Store number used to scope deletion"
                    },
                    {
                        "name": "station",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" },
                        "description": "Station ID"
                    }
                ],
                "responses": {
                    "204": { "description": "Station deleted" },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        },
        "/{storeId}/tokens/stations/{station}": {
            "post": {
                "tags": ["Tokens"],
                "summary": "Issue station token",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "station",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Station token created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "server_url": { "type": "string" },
                                        "storeId": { "type": "string" },
                                        "store_id": { "type": "integer" },
                                        "room": { "type": "string" },
                                        "token": { "type": "string" }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        },
        "/{storeId}/tokens/supervisor": {
            "post": {
                "tags": ["Tokens"],
                "summary": "Issue supervisor tokens for all store rooms",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" },
                        "description": "Store number"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Room-scoped supervisor tokens",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "server_url": { "type": "string" },
                                        "storeId": { "type": "string" },
                                        "store_id": { "type": "integer" },
                                        "identity": { "type": "string" },
                                        "rooms": {
                                            "type": "array",
                                            "items": { "type": "string" }
                                        },
                                        "tokens": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "room": {
                                                        "type": "string"
                                                    },
                                                    "token": {
                                                        "type": "string"
                                                    }
                                                }
                                            }
                                        },
                                        "permissions": {
                                            "type": "object",
                                            "additionalProperties": {
                                                "type": "boolean"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        }
    },
    "components": {
        "responses": {
            "ValidationError": {
                "description": "Validation error",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": { "type": "string" },
                                "errors": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "array",
                                        "items": { "type": "string" }
                                    }
                                }
                            }
                        },
                        "example": {
                            "message": "The given data was invalid.",
                            "errors": {
                                "storeId": ["The storeId field is required."]
                            }
                        }
                    }
                }
            },
            "NotFound": {
                "description": "Resource not found",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": { "type": "string" }
                            }
                        },
                        "example": {
                            "message": "No query results for model [App\\Models\\Store]."
                        }
                    }
                }
            }
        },
        "schemas": {
            "Station": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer" },
                    "store_id": { "type": "integer" },
                    "name": { "type": "string" },
                    "room_name": { "type": "string" },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                }
            },
            "IssuedToken": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer" },
                    "scope": { "type": "string" },
                    "identity": { "type": "string" },
                    "room": { "type": "string", "nullable": true },
                    "token_hash": { "type": "string" },
                    "issued_at": { "type": "string", "format": "date-time" },
                    "expires_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "revoked_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "metadata": {
                        "type": "object",
                        "additionalProperties": true,
                        "nullable": true
                    },
                    "created_at": { "type": "string", "format": "date-time" },
                    "updated_at": { "type": "string", "format": "date-time" }
                }
            },
            "PaginatedIssuedTokens": {
                "type": "object",
                "properties": {
                    "current_page": { "type": "integer" },
                    "data": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/IssuedToken" }
                    },
                    "first_page_url": { "type": "string" },
                    "from": { "type": "integer", "nullable": true },
                    "last_page": { "type": "integer" },
                    "last_page_url": { "type": "string" },
                    "links": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "url": { "type": "string", "nullable": true },
                                "label": { "type": "string" },
                                "active": { "type": "boolean" }
                            }
                        }
                    },
                    "next_page_url": { "type": "string", "nullable": true },
                    "path": { "type": "string" },
                    "per_page": { "type": "integer" },
                    "prev_page_url": { "type": "string", "nullable": true },
                    "to": { "type": "integer", "nullable": true },
                    "total": { "type": "integer" }
                }
            },
            "VideoGrantInput": {
                "type": "object",
                "properties": {
                    "room": { "type": "string" },
                    "room_join": { "type": "boolean" },
                    "room_admin": { "type": "boolean" },
                    "room_create": { "type": "boolean" },
                    "room_list": { "type": "boolean" },
                    "room_record": { "type": "boolean" },
                    "ingress_admin": { "type": "boolean" },
                    "can_publish": { "type": "boolean" },
                    "can_subscribe": { "type": "boolean" },
                    "can_publish_data": { "type": "boolean" },
                    "can_update_own_metadata": { "type": "boolean" },
                    "can_subscribe_metrics": { "type": "boolean" },
                    "hidden": { "type": "boolean" },
                    "recorder": { "type": "boolean" }
                }
            },
            "ParticipantPermissionInput": {
                "type": "object",
                "properties": {
                    "can_subscribe": { "type": "boolean" },
                    "can_publish": { "type": "boolean" },
                    "can_publish_data": { "type": "boolean" },
                    "can_publish_sources": {
                        "type": "array",
                        "items": {
                            "type": "integer",
                            "description": "LiveKit TrackSource enum value"
                        }
                    },
                    "hidden": { "type": "boolean" },
                    "recorder": { "type": "boolean" },
                    "can_update_metadata": { "type": "boolean" },
                    "agent": { "type": "boolean" },
                    "can_subscribe_metrics": { "type": "boolean" }
                }
            },
            "Room": {
                "type": "object",
                "description": "LiveKit Room object (server-provided fields)",
                "additionalProperties": true
            },
            "ListRoomsResponse": {
                "type": "object",
                "properties": {
                    "rooms": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/Room" }
                    }
                },
                "additionalProperties": true
            },
            "ParticipantInfo": {
                "type": "object",
                "description": "LiveKit ParticipantInfo object (server-provided fields)",
                "additionalProperties": true
            },
            "ListParticipantsResponse": {
                "type": "object",
                "properties": {
                    "participants": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ParticipantInfo"
                        }
                    }
                },
                "additionalProperties": true
            }
        }
    }
}
