{
    "openapi": "3.1.0",
    "info": {
        "title": "ScreensPizza API",
        "version": "1.0.0",
        "description": "Comprehensive API specification for station management and LiveKit administration.\n\nStore scoping model:\n- `storeId` is the external store number (`stores.store_number`, string).\n- API resolves `storeId` to internal numeric `stores.id` before querying stations/rooms.\n- Store-scoped endpoints return 404 when target resources do not belong to the provided store."
    },
    "servers": [
        {
            "url": "/api",
            "description": "Laravel API base path"
        }
    ],
    "tags": [
        { "name": "Stations" },
        { "name": "StationMedia" },
        { "name": "Tokens" }
    ],
    "paths": {
        "/{storeId}/stations": {
            "get": {
                "tags": ["Stations"],
                "summary": "List stations",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "description": "External store number (`stores.store_number`).",
                        "schema": { "type": "string" },
                        "example": "S-1001"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Stations list",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Station"
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" }
                }
            },
            "post": {
                "tags": ["Stations"],
                "summary": "Create station",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "description": "External store number (`stores.store_number`).",
                        "schema": { "type": "string" },
                        "example": "S-1001"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["name", "room_name"],
                                "properties": {
                                    "name": { "type": "string" },
                                    "room_name": { "type": "string" }
                                }
                            },
                            "example": {
                                "name": "Counter 1",
                                "room_name": "store-1001-counter-1"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Station created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Station"
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        },
        "/{storeId}/stations/{station}": {
            "delete": {
                "tags": ["Stations"],
                "summary": "Delete station",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" },
                        "description": "Store number used to scope deletion"
                    },
                    {
                        "name": "station",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" },
                        "description": "Station ID"
                    }
                ],
                "responses": {
                    "204": { "description": "Station deleted" },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        },
        "/{storeId}/stations/password": {
            "post": {
                "tags": ["Stations"],
                "summary": "Set shared station password",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" },
                        "description": "Store number used to scope password"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["password"],
                                "properties": {
                                    "password": { "type": "string" }
                                }
                            },
                            "example": {
                                "password": "station-shared-secret"
                            }
                        }
                    }
                },
                "responses": {
                    "204": { "description": "Station password set" },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        },
        "/{storeId}/stations/{station}/media": {
            "get": {
                "tags": ["StationMedia"],
                "summary": "List station media",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "station",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Station media list",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "station_id": { "type": "integer" },
                                        "media": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/StationMedia"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" }
                }
            }
        },
        "/{storeId}/stations/{station}/media/uploads": {
            "post": {
                "tags": ["StationMedia"],
                "summary": "Init chunked media upload",
                "description": "Start a chunked upload. This API is stateless: the server does not track uploads beyond storing chunks on disk. Steps:\n1) Pick a chunk size within server limits (upload_max_filesize/post_max_size).\n2) Split the file into N parts and number them 0..N-1.\n3) Call this endpoint with total_chunks=N to get upload_id.\n4) Upload each chunk with PUT /media/uploads/{upload}/chunks/{chunkIndex} using multipart form field 'chunk'.\n5) Call the complete endpoint with the same total_chunks and metadata to assemble the file.",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "station",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["total_chunks"],
                                "properties": {
                                    "total_chunks": { "type": "integer" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Upload session created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "upload_id": { "type": "string" },
                                        "station_id": { "type": "integer" },
                                        "total_chunks": { "type": "integer" }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        },
        "/{storeId}/stations/{station}/media/uploads/{upload}/chunks/{chunkIndex}": {
            "put": {
                "tags": ["StationMedia"],
                "summary": "Upload a media chunk",
                "description": "Upload one chunk (binary). chunkIndex is zero-based. Chunks can be uploaded in any order; re-uploading the same chunkIndex overwrites the previous part. Use upload_id from the init endpoint.",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "station",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    },
                    {
                        "name": "upload",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "chunkIndex",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "required": ["chunk"],
                                "properties": {
                                    "chunk": {
                                        "type": "string",
                                        "format": "binary"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Chunk stored",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "upload_id": { "type": "string" },
                                        "chunk_index": { "type": "integer" },
                                        "path": { "type": "string" }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        },
        "/{storeId}/stations/{station}/media/uploads/{upload}/complete": {
            "post": {
                "tags": ["StationMedia"],
                "summary": "Finalize a chunked upload",
                "description": "Finalize an upload by assembling chunks 0..N-1 in order. The server verifies all chunks exist and the final size matches total_size, then writes the final file to public storage and creates the media record. If is_primary is true, the existing primary media is cleared. Returns 422 if chunks are missing or size mismatch.",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "station",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    },
                    {
                        "name": "upload",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "type",
                                    "file_name",
                                    "total_size",
                                    "total_chunks"
                                ],
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "enum": ["image", "video"]
                                    },
                                    "file_name": { "type": "string" },
                                    "mime_type": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "total_size": { "type": "integer" },
                                    "total_chunks": { "type": "integer" },
                                    "duration_seconds": {
                                        "type": "integer",
                                        "nullable": true
                                    },
                                    "width": {
                                        "type": "integer",
                                        "nullable": true
                                    },
                                    "height": {
                                        "type": "integer",
                                        "nullable": true
                                    },
                                    "is_primary": { "type": "boolean" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Media created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "media": {
                                            "$ref": "#/components/schemas/StationMedia"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        },
        "/{storeId}/stations/{station}/media/uploads/complete-bulk": {
            "post": {
                "tags": ["StationMedia"],
                "summary": "Finalize multiple uploads",
                "description": "Finalize multiple uploads in one request. Provide one entry per upload_id with the same metadata you would send to the single complete endpoint. Each upload is assembled independently; failures return per-item errors.",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "station",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["uploads"],
                                "properties": {
                                    "uploads": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "required": [
                                                "upload_id",
                                                "type",
                                                "file_name",
                                                "total_size",
                                                "total_chunks"
                                            ],
                                            "properties": {
                                                "upload_id": {
                                                    "type": "string"
                                                },
                                                "type": {
                                                    "type": "string",
                                                    "enum": ["image", "video"]
                                                },
                                                "file_name": {
                                                    "type": "string"
                                                },
                                                "mime_type": {
                                                    "type": "string",
                                                    "nullable": true
                                                },
                                                "total_size": {
                                                    "type": "integer"
                                                },
                                                "total_chunks": {
                                                    "type": "integer"
                                                },
                                                "duration_seconds": {
                                                    "type": "integer",
                                                    "nullable": true
                                                },
                                                "width": {
                                                    "type": "integer",
                                                    "nullable": true
                                                },
                                                "height": {
                                                    "type": "integer",
                                                    "nullable": true
                                                },
                                                "is_primary": {
                                                    "type": "boolean"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Bulk completion results",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "results": {
                                            "type": "array",
                                            "items": { "type": "object" }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        },
        "/{storeId}/stations/{station}/media/{media}/primary": {
            "post": {
                "tags": ["StationMedia"],
                "summary": "Set primary media",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "station",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    },
                    {
                        "name": "media",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Primary media set",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "media": {
                                            "$ref": "#/components/schemas/StationMedia"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" }
                }
            }
        },
        "/{storeId}/stations/{station}/media/bulk": {
            "delete": {
                "tags": ["StationMedia"],
                "summary": "Bulk delete station media",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "station",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["ids"],
                                "properties": {
                                    "ids": {
                                        "type": "array",
                                        "items": { "type": "integer" }
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Media deleted",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "deleted_ids": {
                                            "type": "array",
                                            "items": { "type": "integer" }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        },
        "/{storeId}/tokens/stations/{station}": {
            "post": {
                "tags": ["Tokens"],
                "summary": "Issue station token",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "station",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["password"],
                                "properties": {
                                    "password": { "type": "string" }
                                }
                            },
                            "example": {
                                "password": "station-shared-secret"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Station token created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "server_url": { "type": "string" },
                                        "storeId": { "type": "string" },
                                        "store_id": { "type": "integer" },
                                        "room": { "type": "string" },
                                        "token": { "type": "string" },
                                        "media": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/StationMedia"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "403": { "$ref": "#/components/responses/Forbidden" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        },
        "/{storeId}/tokens/supervisor": {
            "post": {
                "tags": ["Tokens"],
                "summary": "Issue supervisor tokens for all store rooms",
                "parameters": [
                    {
                        "name": "storeId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" },
                        "description": "Store number"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Room-scoped supervisor tokens",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "server_url": { "type": "string" },
                                        "storeId": { "type": "string" },
                                        "store_id": { "type": "integer" },
                                        "identity": { "type": "string" },
                                        "rooms": {
                                            "type": "array",
                                            "items": { "type": "string" }
                                        },
                                        "tokens": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "room": {
                                                        "type": "string"
                                                    },
                                                    "token": {
                                                        "type": "string"
                                                    },
                                                    "media": {
                                                        "type": "array",
                                                        "items": {
                                                            "$ref": "#/components/schemas/StationMedia"
                                                        }
                                                    }
                                                }
                                            }
                                        },
                                        "permissions": {
                                            "type": "object",
                                            "additionalProperties": {
                                                "type": "boolean"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "$ref": "#/components/responses/NotFound" },
                    "422": { "$ref": "#/components/responses/ValidationError" }
                }
            }
        }
    },
    "components": {
        "responses": {
            "ValidationError": {
                "description": "Validation error",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": { "type": "string" },
                                "errors": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "array",
                                        "items": { "type": "string" }
                                    }
                                }
                            }
                        },
                        "example": {
                            "message": "The given data was invalid.",
                            "errors": {
                                "storeId": ["The storeId field is required."]
                            }
                        }
                    }
                }
            },
            "NotFound": {
                "description": "Resource not found",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": { "type": "string" }
                            }
                        },
                        "example": {
                            "message": "No query results for model [App\\Models\\Store]."
                        }
                    }
                }
            },
            "Forbidden": {
                "description": "Forbidden",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": { "type": "string" }
                            }
                        },
                        "example": {
                            "message": "Invalid station password."
                        }
                    }
                }
            }
        },
        "schemas": {
            "Station": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer" },
                    "store_id": { "type": "integer" },
                    "name": { "type": "string" },
                    "room_name": { "type": "string" },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                }
            },
            "StationMedia": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer" },
                    "station_id": { "type": "integer" },
                    "type": { "type": "string", "enum": ["image", "video"] },
                    "is_primary": { "type": "boolean" },
                    "url": { "type": "string" },
                    "file_name": { "type": "string", "nullable": true },
                    "mime_type": { "type": "string", "nullable": true },
                    "size_bytes": { "type": "integer", "nullable": true },
                    "duration_seconds": { "type": "integer", "nullable": true },
                    "width": { "type": "integer", "nullable": true },
                    "height": { "type": "integer", "nullable": true },
                    "created_at": { "type": "string", "format": "date-time" },
                    "updated_at": { "type": "string", "format": "date-time" }
                }
            },
            "IssuedToken": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer" },
                    "scope": { "type": "string" },
                    "identity": { "type": "string" },
                    "room": { "type": "string", "nullable": true },
                    "token_hash": { "type": "string" },
                    "issued_at": { "type": "string", "format": "date-time" },
                    "expires_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "revoked_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "metadata": {
                        "type": "object",
                        "additionalProperties": true,
                        "nullable": true
                    },
                    "created_at": { "type": "string", "format": "date-time" },
                    "updated_at": { "type": "string", "format": "date-time" }
                }
            },
            "PaginatedIssuedTokens": {
                "type": "object",
                "properties": {
                    "current_page": { "type": "integer" },
                    "data": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/IssuedToken" }
                    },
                    "first_page_url": { "type": "string" },
